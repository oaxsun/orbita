rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    match /articles/{articleId} {
      allow read: if true;
      allow create, update, delete: if signedIn();
    }

    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if signedIn();
    }

    match /siteConfig/{docId} {
      allow read: if true;
      allow create, update, delete: if signedIn();
    }
  }
}
